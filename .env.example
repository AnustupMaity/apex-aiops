# ============================================================
# Project Apex — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
MCP_DB_URL=postgresql://apex_mcp_role:mcp_restricted_pass123@db.your-project.supabase.co:5432/postgres

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# --- LangSmith ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=project-apex
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Cloud LLM (Escalation) ---
# Primary: Gemini
GEMINI_API_KEY=your-gemini-api-key
# Fallback 1: Groq
GROQ_API_KEY=your-groq-api-key
# Fallback 2: OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Kaggle ---
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key

# --- Model Hyperparameters ---
ANOMALY_THRESHOLD=0.85
BILSTM_HIDDEN_SIZE=64
BILSTM_NUM_LAYERS=2
BILSTM_DROPOUT=0.3
BILSTM_SEQ_LEN=60
BATCH_SIZE=16
LEARNING_RATE=0.001
NUM_EPOCHS=100
EARLY_STOP_PATIENCE=10
GRADIENT_ACCUMULATION_STEPS=4

# --- Telemetry ---
TELEMETRY_POLL_INTERVAL_SECONDS=5
TELEMETRY_BUFFER_SIZE=300

# --- Daemon ---
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8000
